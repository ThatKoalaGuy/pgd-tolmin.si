---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import sos112 from '../images/sos112.png';
---

<Layout title="Kontakt | PGD Tolmin">
	<section class="relative overflow-hidden bg-stone-900">
		<div class="absolute inset-0 pointer-events-none">
			<div
				class="absolute -top-20 -right-20 h-96 w-96 rounded-full bg-red-600/20 blur-3xl"
			>
			</div>
			<div
				class="absolute bottom-0 left-0 h-px w-full bg-linear-to-r from-transparent via-red-600 to-transparent"
			>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-6 py-16 md:py-20 relative">
			<p
				class="text-red-500 text-xs font-bold tracking-[0.25em] uppercase mb-3"
			>
				PGD Tolmin
			</p>
			<div class="md:flex md:items-end md:justify-between gap-8">
				<div>
					<h1
						class="m-0 text-5xl md:text-7xl font-black text-white leading-none tracking-tight"
					>
						Kontakt
					</h1>
					<p
						class="mt-5 max-w-2xl text-stone-300 text-base md:text-lg leading-relaxed"
					>
						Stopite v stik z nami za informacije, pomoč ali sodelovanje. Za
						nujne primere pa vedno pokličite 112.
					</p>
				</div>

				<div
					class="hidden md:block mt-8 md:mt-0 md:ml-auto w-full md:w-auto max-w-md rounded-3xl border border-red-400/40 bg-linear-to-br from-red-600 to-red-700 px-6 py-5 md:px-8 md:py-7 shadow-2xl shadow-red-950/30 ring-1 ring-white/10 overflow-hidden"
					aria-label="Nujni primeri 112"
				>
					<div
						class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-white/10 blur-2xl"
					>
					</div>
					<div class="relative flex items-start gap-4">
						<div
							class="mt-1 h-3 w-3 rounded-full bg-white shadow-[0_0_0_6px_rgba(255,255,255,0.18)] animate-pulse"
						>
						</div>
						<div class="space-y-2">
							<p
								class="text-red-100 text-xs md:text-sm font-bold tracking-[0.3em] uppercase"
							>
								V nujnih primerih
							</p>
							<p
								class="text-white text-3xl md:text-4xl font-black leading-none tracking-tight"
							>
								Pokličite 112
							</p>
							<p
								class="max-w-xs text-red-50/90 text-sm leading-relaxed md:hidden"
							>
								Če je vaše ali tuje življenje v hudi nevarnosti, takoj pokličite
								112. Kliknite tukaj, da začnete klic.
							</p>
						</div>
					</div>
				</div>

				<a
					href="tel:112"
					class="mt-8 md:hidden w-full rounded-3xl border border-red-400/40 bg-linear-to-br from-red-600 to-red-700 px-6 py-5 shadow-2xl shadow-red-950/30 ring-1 ring-white/10 transition-transform hover:-translate-y-0.5 hover:shadow-red-950/40 focus:outline-none focus:ring-2 focus:ring-white/70 block overflow-hidden"
					aria-label="Pokliči 112"
				>
					<div
						class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-white/10 blur-2xl"
					>
					</div>
					<div class="relative flex items-start gap-4">
						<div
							class="mt-1 h-3 w-3 rounded-full bg-white shadow-[0_0_0_6px_rgba(255,255,255,0.18)] animate-pulse"
						>
						</div>
						<div class="space-y-2">
							<p
								class="text-red-100 text-xs font-bold tracking-[0.3em] uppercase"
							>
								V nujnih primerih
							</p>
							<p
								class="text-white text-3xl font-black leading-none tracking-tight"
							>
								Pokličite 112
							</p>
							<p class="max-w-xs text-red-50/90 text-sm leading-relaxed">
								Če je vaše ali tuje življenje v hudi nevarnosti, takoj pokličite
								112. Kliknite tukaj, da začnete klic.
							</p>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<div class="bg-stone-50">
		<div class="max-w-7xl mx-auto px-6 py-16 space-y-8">
			<div class="grid gap-8 lg:grid-cols-5 items-start">
				<section
					aria-label="Kontakt podatki"
					class="contact-card lg:col-span-2 rounded-2xl bg-white border border-stone-200 shadow-sm overflow-hidden"
				>
					<div class="h-1 w-full bg-linear-to-r from-red-600 to-red-400"></div>
					<div class="p-6 md:p-8 space-y-6">
						<div>
							<p
								class="text-xs font-bold tracking-[0.2em] uppercase text-stone-400 mb-3"
							>
								Kontakt podatki
							</p>
							<address
								class="not-italic text-stone-900 space-y-1 leading-relaxed"
							>
								<div class="font-black text-xl">
									Prostovoljno gasilsko društvo Tolmin
								</div>
								<div class="text-stone-600">Lavričeva ulica 1, Tolmin</div>
								<div class="text-stone-600">5220 Tolmin</div>
							</address>
						</div>

						<div class="space-y-3 text-sm text-stone-600">
							<p class="m-0">
								Davčna številka: <span class="font-semibold text-stone-900"
									>19599056</span
								><br />
								Matična številka: <span class="font-semibold text-stone-900"
									>5154251000</span
								>
							</p>
							<p class="m-0">
								E-pošta:
								<a
									class="block break-all font-semibold text-red-700 hover:text-red-600 transition-colors"
									href="mailto:pgdtolmin@gmail.com"
								>
									pgdtolmin@gmail.com
								</a>
							</p>
							<p class="m-0">Uradne ure: Vsak torek od 20 dalje</p>
						</div>

						<a
							href="https://www.gov.si/teme/klic-v-sili/"
							target="_blank"
							rel="noopener noreferrer"
							class="block rounded-xl border border-stone-200 bg-stone-50 p-3 transition-transform hover:-translate-y-0.5 hover:shadow-md"
						>
							<Image src={sos112} alt="SOS 112" class="w-full h-auto" />
						</a>
					</div>
				</section>

				<section aria-label="Kje smo" class="lg:col-span-3 space-y-3">
					<div class="flex items-end justify-between gap-4">
						<div>
							<p
								class="text-xs font-bold tracking-[0.2em] uppercase text-stone-400 mb-2"
							>
								Kje smo
							</p>
							<h2
								class="m-0 text-2xl md:text-3xl font-black text-stone-900 tracking-tight"
							>
								Naša lokacija v Tolminu
							</h2>
						</div>
					</div>
					<div
						class="rounded-2xl overflow-hidden border border-stone-200 shadow-sm bg-white"
					>
						<div class="aspect-4/3 md:aspect-16/10">
							<iframe
								class="w-full h-full border-0"
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								allowfullscreen
								src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6656.370899370995!2d13.73960082625043!3d46.181411867522804!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x477af7b16949cbd5%3A0xed37120e868719f6!2sProstovoljno%20gasilsko%20dru%C5%A1tvo%20Tolmin!5e1!3m2!1ssl!2ssi!4v1761409913201!5m2!1ssl!2ssi"
							></iframe>
						</div>
					</div>
				</section>
			</div>
		</div>
	</div>
</Layout>

<style>
	.contact-card {
		opacity: 0;
		transform: translateY(20px);
		animation: fadeUp 0.5s ease-out forwards;
	}

	@keyframes fadeUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
