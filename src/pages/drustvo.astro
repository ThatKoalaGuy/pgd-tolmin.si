---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Društvo | PGD Tolmin"
	description="O društvu, zgodovina, vodstvo in članstvo PGD Tolmin."
>
	<!-- Hero -->
	<div class="relative bg-stone-900 overflow-hidden">
		<div class="absolute inset-0 pointer-events-none">
			<div
				class="absolute -top-20 -right-20 w-96 h-96 bg-red-600/20 rounded-full blur-3xl"
			>
			</div>
			<div
				class="absolute bottom-0 left-0 w-full h-px bg-linear-to-r from-transparent via-red-600 to-transparent"
			>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-6 py-20 relative">
			<p
				class="text-red-500 text-xs font-bold tracking-[0.25em] uppercase mb-3"
			>
				PGD Tolmin
			</p>
			<h1
				class="text-5xl md:text-7xl font-black text-white leading-none tracking-tight"
			>
				Društvo
			</h1>
			<p
				class="mt-6 max-w-2xl text-stone-300 text-base md:text-lg leading-relaxed"
			>
				Prostovoljno gasilsko društvo Tolmin – zgodovina, poslanstvo in
				organizacija. Tukaj predstavljamo, kdo smo in kako delujemo za varnost
				skupnosti.
			</p>
		</div>
	</div>

	<!-- Content -->
	<div class="bg-stone-50">
		<div class="max-w-7xl mx-auto px-6 py-16 space-y-12">
			<!-- About / History (polished) -->
			<section
				class="rounded-2xl bg-white border border-stone-200 p-8 shadow-sm"
			>
				<div class="md:flex md:gap-8">
					<div class="md:flex-1">
						<h2 class="text-2xl font-black text-stone-900 mb-3">O društvu</h2>
						<p class="text-stone-600 leading-relaxed">
							PGD Tolmin deluje od leta <strong>1881</strong>. Smo prostovoljna
							organizacija, ki skrbi za varnost prebivalcev Tolmina in okolice.
							Naše delo vključuje gašenje, tehnične intervencije in reševanje ob
							naravnih nesrečah.
						</p>
					</div>

					<div class="md:w-64 mt-6 md:mt-0">
						<div
							class="rounded-lg bg-stone-50 p-4 border border-stone-200 text-center"
						>
							<p
								class="text-stone-400 text-xs uppercase tracking-wide font-bold"
							>
								Ustanovitev
							</p>
							<p class="mt-2 text-2xl font-black text-stone-900">1881</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Leadership / Team (polished) -->
			<section
				class="rounded-2xl bg-white border border-stone-200 p-8 shadow-sm"
			>
				<h2 class="text-2xl font-black text-stone-900 mb-6">Vodstvo</h2>
				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="p-4 bg-stone-50 rounded-lg border border-stone-200">
						<p class="font-black text-stone-900">Jure Beguš</p>
						<p class="text-sm text-stone-600">Poveljnik</p>
					</div>

					<div class="p-4 bg-stone-50 rounded-lg border border-stone-200">
						<p class="font-black text-stone-900">David Rejc</p>
						<p class="text-sm text-stone-600">Predsednik</p>
					</div>
				</div>
			</section>
		</div>
	</div>

	<style>
		.section-card {
			opacity: 0;
			transform: translateY(20px);
			animation: fadeUp 0.5s ease-out forwards;
		}

		/* leader-card hover and avatar removed per user request */

		@keyframes fadeUp {
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	</style>
</Layout>
