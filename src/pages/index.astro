---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import gd from '../images/gd.jpg';
import qrCode from '../images/qr-code.png';
---

<Layout
	title="PGD Tolmin"
	fullBleed={true}
	hideFooter={false}
	bodyClass=""
	viewportFit={true}
>
	<section class="relative min-h-dvh overflow-hidden bg-black">
		<!-- Full-bleed hero image -->
		<Image
			src={gd}
			alt="GD"
			class="absolute inset-0 w-full h-full object-cover rounded-none shadow-none z-20"
			widths={[640, 768, 1024, 1280, 1536]}
			sizes="100vw"
		/>

		<!-- Uniform overlay over the entire image -->
		<div class="absolute inset-0 bg-black/30 z-30 pointer-events-none"></div>

		<!-- Headings overlay -->
		<div
			class="absolute inset-0 z-40 flex items-center justify-center mb-24 sm:mb-0"
		>
			<div class="text-center px-4 sm:px-6 animate-fade-in">
				<h1
					class="m-0 text-white text-4xl sm:text-6xl md:text-8xl font-bold drop-shadow-lg"
				>
					PGD Tolmin
				</h1>
				<h2
					class="m-0 mt-2 sm:mt-3 text-white text-lg sm:text-3xl md:text-4xl drop-shadow"
				>
					Tukaj - za vas.
				</h2>
			</div>
		</div>

		<!-- QR Code Blob - Bottom Left (desktop) -->
		<div
			class="absolute z-40 hidden sm:block overflow-hidden"
			style="left: max(1rem, env(safe-area-inset-left)); bottom: max(1rem, env(safe-area-inset-bottom));"
		>
			<div class="relative w-64 md:w-72 group">
				<!-- Glow: overflow-hidden on parent clips this safely -->
				<div
					class="absolute inset-0 bg-red-600 rounded-full blur-2xl opacity-60"
				>
				</div>

				<div
					class="relative bg-white/95 backdrop-blur-sm rounded-3xl px-5 py-3 shadow-2xl"
				>
					<p
						class="text-center text-xs md:text-sm font-medium text-gray-700 mb-2"
					>
						Podprite nas in namenite 1% dohodnine PGD Tolmin! <br />
						Poiščite nas pod davčno številko
						<!-- FIX: <b> replaced with <button> for keyboard/a11y; unique id "copy-tax-number-desktop" -->
						<button
							id="copy-tax-number-desktop"
							type="button"
							class="text-lg sm:text-xl font-bold hover:text-red-600 cursor-pointer transition-colors inline-flex items-center gap-1 bg-transparent border-0 p-0"
							title="Klikni za kopiranje"
						>
							19599056
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
								<path
									d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
								></path>
							</svg>
						</button>
						<!-- FIX: unique id "copy-feedback-desktop" -->
						<span
							id="copy-feedback-desktop"
							class="text-xs text-green-600 ml-1 hidden">✓ Kopirano!</span
						>
					</p>
					<a
						href="https://edavki.durs.si/edavkiportal/OpenPortal/CommonPages/Opdynp/PageD.aspx?category=namenitev_dela_dohodnine_fo"
						target="_blank"
						rel="noopener noreferrer"
						class="block transition-transform hover:scale-105"
					>
						<div class="flex justify-center">
							<Image src={qrCode} alt="QR Code" class="w-36 md:w-40 h-auto" />
						</div>
						<p
							class="text-center text-sm text-gray-600 mt-2 group-hover:text-red-600 transition-colors"
						>
							👆 Klikni za oddajo
						</p>
					</a>
				</div>
			</div>
		</div>

		<!-- Mobile FAB + Donation Panel -->
		<!-- FIX: z-[60] instead of non-standard z-60 -->
		<div
			class="fixed z-60 sm:hidden"
			style="bottom: max(4rem, env(safe-area-inset-bottom)); left: max(1rem, env(safe-area-inset-left));"
		>
			<div class="relative">
				<button
					id="donation-toggle"
					type="button"
					class="flex h-12 w-12 items-center justify-center rounded-full bg-red-600 text-white shadow-xl shadow-red-600/30 focus:outline-none focus:ring-2 focus:ring-white/80"
					aria-controls="donation-panel"
					aria-expanded="false"
					aria-label="Odpri donacijski obrazec"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-6 w-6"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M12 5v14M5 12h14"></path>
					</svg>
				</button>

				<div
					id="donation-panel"
					class="absolute bottom-full left-0 mb-3 w-[min(18rem,calc(100vw-2rem))] rounded-2xl border border-stone-200 bg-white/95 p-3 shadow-2xl backdrop-blur-sm opacity-0 translate-y-2 scale-95 pointer-events-none transition-all duration-200 ease-out"
					role="dialog"
					aria-modal="false"
					aria-label="Donacijski obrazec"
				>
					<button
						id="donation-close"
						type="button"
						class="absolute right-2 top-2 flex h-8 w-8 items-center justify-center rounded-full bg-stone-100 text-gray-600 transition-colors hover:bg-stone-200 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-600/40"
						aria-label="Zapri donacijski obrazec"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>

					<div class="mb-2 flex items-start justify-between gap-3 pr-10">
						<p class="text-sm font-semibold text-gray-900">
							Podprite PGD Tolmin z 1% dohodnine.
						</p>
					</div>

					<p class="mb-2 text-xs leading-5 text-gray-700">
						Poiščite nas pod davčno številko
						<!-- FIX: <b> replaced with <button>; unique id "copy-tax-number-mobile"; cursor-pointer added -->
						<button
							id="copy-tax-number-mobile"
							type="button"
							class="inline-flex items-center gap-1 text-sm font-bold text-red-700 cursor-pointer bg-transparent border-0 p-0"
							title="Klikni za kopiranje"
						>
							19599056
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
								<path
									d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
								></path>
							</svg>
						</button>
						<!-- FIX: unique id "copy-feedback-mobile" -->
						<span
							id="copy-feedback-mobile"
							class="ml-1 hidden text-xs text-green-600">✓ Kopirano!</span
						>
					</p>

					<a
						href="https://edavki.durs.si/edavkiportal/OpenPortal/CommonPages/Opdynp/PageD.aspx?category=namenitev_dela_dohodnine_fo"
						target="_blank"
						rel="noopener noreferrer"
						class="block rounded-xl border border-stone-200 bg-stone-50 p-2 transition-transform active:scale-[0.99]"
					>
						<div class="mx-auto flex w-32 justify-center">
							<Image src={qrCode} alt="QR Code" class="h-auto w-full" />
						</div>
						<p class="mt-2 text-center text-xs font-medium text-gray-600">
							Pritisni za oddajo obrazca
						</p>
					</a>
				</div>
			</div>
		</div>
	</section>

	<script>
		function initPage() {
			const donationToggle = document.getElementById('donation-toggle');
			const donationPanel = document.getElementById('donation-panel');
			const donationClose = document.getElementById('donation-close');

			const openDonationPanel = () => {
				donationToggle?.setAttribute('aria-expanded', 'true');
				donationPanel?.classList.remove(
					'opacity-0',
					'translate-y-2',
					'scale-95',
					'pointer-events-none',
				);
				donationPanel?.classList.add(
					'opacity-100',
					'translate-y-0',
					'scale-100',
					'pointer-events-auto',
				);
			};

			const closeDonationPanel = () => {
				donationToggle?.setAttribute('aria-expanded', 'false');
				donationPanel?.classList.add(
					'opacity-0',
					'translate-y-2',
					'scale-95',
					'pointer-events-none',
				);
				donationPanel?.classList.remove(
					'opacity-100',
					'translate-y-0',
					'scale-100',
					'pointer-events-auto',
				);
			};

			donationToggle?.addEventListener('click', () => {
				const isOpen = donationToggle.getAttribute('aria-expanded') === 'true';
				isOpen ? closeDonationPanel() : openDonationPanel();
			});

			donationClose?.addEventListener('click', closeDonationPanel);

			// FIX: close panel when clicking outside
			document.addEventListener('click', (e) => {
				const panel = document.getElementById('donation-panel');
				const toggle = document.getElementById('donation-toggle');
				if (
					panel &&
					toggle &&
					!panel.contains(e.target as Node) &&
					!toggle.contains(e.target as Node) &&
					toggle.getAttribute('aria-expanded') === 'true'
				) {
					closeDonationPanel();
				}
			});

			// FIX: separate copy handlers for desktop and mobile with their own feedback spans
			const copyTaxNumber = async (feedbackId: string) => {
				try {
					await navigator.clipboard.writeText('19599056');
					const feedback = document.getElementById(feedbackId);
					feedback?.classList.remove('hidden');
					setTimeout(() => feedback?.classList.add('hidden'), 2000);
				} catch (err) {
					console.error('Failed to copy:', err);
				}
			};

			document
				.getElementById('copy-tax-number-desktop')
				?.addEventListener('click', () =>
					copyTaxNumber('copy-feedback-desktop'),
				);

			document
				.getElementById('copy-tax-number-mobile')
				?.addEventListener('click', () =>
					copyTaxNumber('copy-feedback-mobile'),
				);
		}

		// FIX: supports Astro view transitions if ever enabled
		document.addEventListener('astro:page-load', initPage);
		initPage();
	</script>

	<style>
		@keyframes fade-in {
			from {
				opacity: 0;
				transform: translateY(12px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		.animate-fade-in {
			animation: fade-in 0.8s ease-out both;
		}
	</style>
</Layout>
